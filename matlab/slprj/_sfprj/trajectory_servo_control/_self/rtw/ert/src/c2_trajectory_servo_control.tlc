%implements "chartSource" "C"
%function ChartConfig(block, system) void
  %createrecord chartConfiguration { ...
          executeAtInitialization  0 ...
  }
  %return chartConfiguration
%endfunction
%function ChartDataMap(block, system) void
  %createrecord ChartDataElements {\
    NumChartData   10 \
    ChartDataDefaults {\
      RecordType   "ChartData"\
      Dimensions   []\
      IsTestPoint  0\
    }\
    ChartData {\
      Name         "sfEvent"\
      Description  "ActiveChartEvent"\
      SFName       ""\
      Path         ""\
      SrcLocation  ""\
    }\
    ChartData {\
      Name         "doneDoubleBufferReInit"\
      Description  "DoubleBufferInitCheck"\
      SFName       ""\
      Path         ""\
      SrcLocation  ""\
    }\
    ChartData {\
      Name         "count"\
      Description  "EmlPersistent"\
      SFName       ""\
      Path         ""\
      SrcLocation  "trajectory_servo_control:28:344-349"\
    }\
    ChartData {\
      Name         "count_not_empty"\
      Description  "EmlPersistentSentinel"\
      SFName       ""\
      Path         ""\
      SrcLocation  "trajectory_servo_control:28:344-349"\
    }\
    ChartData {\
      Name         "target"\
      Description  "EmlPersistent"\
      SFName       ""\
      Path         ""\
      SrcLocation  "trajectory_servo_control:28:350-356"\
    }\
    ChartData {\
      Name         "target_not_empty"\
      Description  "EmlPersistentSentinel"\
      SFName       ""\
      Path         ""\
      SrcLocation  "trajectory_servo_control:28:350-356"\
    }\
    ChartData {\
      Name         "last_angle"\
      Description  "EmlPersistent"\
      SFName       ""\
      Path         ""\
      SrcLocation  "trajectory_servo_control:28:357-367"\
    }\
    ChartData {\
      Name         "last_angle_not_empty"\
      Description  "EmlPersistentSentinel"\
      SFName       ""\
      Path         ""\
      SrcLocation  "trajectory_servo_control:28:357-367"\
    }\
    ChartData {\
      Name         "pulse_phase"\
      Description  "EmlPersistent"\
      SFName       ""\
      Path         ""\
      SrcLocation  "trajectory_servo_control:28:368-379"\
    }\
    ChartData {\
      Name         "pulse_phase_not_empty"\
      Description  "EmlPersistentSentinel"\
      SFName       ""\
      Path         ""\
      SrcLocation  "trajectory_servo_control:28:368-379"\
    }\
  }
  %return ChartDataElements
%endfunction
